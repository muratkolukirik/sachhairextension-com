---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTASection from '../components/CTASection.astro';
import { SITE, CATEGORIES, GUIDES, WHOLESALE } from '../data/site';

const title = 'Premium Human Hair Extensions Manufacturer';
const description =
  'Sach & Vogue Hair — premium human hair extensions manufacturer in Fethiye / Ölüdeniz. Private label, wholesale supply, 141-colour pigment work, training, and professional salon systems.';
---

<BaseLayout {title} {description} path="/" includeWebsiteSchema>
  <section class="hero">
    <div class="container hero__grid">
      <div class="hero__content">
        <span class="section__eyebrow">Fethiye / Ölüdeniz · Manufacturer</span>
        <h1>Premium human hair extensions, crafted for professional authority</h1>
        <p class="section__lead">
          Sach &amp; Vogue Hair is a production house — not a reseller. We manufacture Tape-In, Keratin Tip, Weft, Clip-In, and Women Topper systems from sorted bulk human hair, with 141-colour pigment work, private label capability, and international salon supply.
        </p>
        <div class="hero__actions">
          <a href="/the-dna-of-sach-hair-extensions/" class="btn">Our manufacturing DNA</a>
          <a href={SITE.whatsapp} class="btn btn--soft" target="_blank" rel="noopener noreferrer">Contact</a>
        </div>
      </div>
      <figure class="hero__visual">
        <img
          src="/images/hero-luxury-hair-extensions.webp"
          alt="Long, voluminous blonde hair extensions styled in a bright minimalist editorial setting"
          width="1672"
          height="941"
          loading="eager"
          decoding="async"
        />
      </figure>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section__header">
        <span class="section__eyebrow">Collection</span>
        <h2>Extension systems for salon work</h2>
        <p class="section__lead">
          Four core manufacturing lines — each built for professional installation, reorder consistency, and natural movement.
        </p>
      </div>
      <div class="catalogue-grid">
        {CATEGORIES.map(({ title: catTitle, href, description: catDesc }, index) => (
          <article class="catalogue-card">
            <span class="catalogue-card__index">{String(index + 1).padStart(2, '0')}</span>
            <h3 class="catalogue-card__title"><a href={href}>{catTitle}</a></h3>
            <p class="catalogue-card__text">{catDesc}</p>
            <a href={href} class="text-link">Discover</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--panel">
    <div class="container editorial-split">
      <div>
        <span class="section__eyebrow">Manufacturer programmes</span>
        <h2>Wholesale, private label &amp; training</h2>
      </div>
      <div>
        <ul class="feature-list">
          {WHOLESALE.map(({ label, href }) => (
            <li><a href={href}><strong>{label}</strong></a> — manufacturer-direct professional supply</li>
          ))}
          <li><a href="/hair-extensions-training/"><strong>Hair Extensions Training</strong></a> — The Extensions Academy for salons and stylists</li>
        </ul>
        <p class="link-group">
          <a href="/professional-salon-supply/" class="text-link">Salon supply overview</a>
        </p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container editorial-split">
      <div>
        <span class="section__eyebrow">Colour authority</span>
        <h2>141 shades &amp; pigment discipline</h2>
      </div>
      <div class="prose">
        <p>
          Our colour library spans natural bases, rooted tones, balayage blends, and fashion shades — produced with professional pigments and batch documentation for reorder stability.
        </p>
        <p class="link-group">
          <a href="/hair-extension-colours-colour-code-guide/" class="text-link">Colour Code Guide</a>
          <span class="link-group__sep" aria-hidden="true">·</span>
          <a href="/hair-extension-colours/" class="text-link">141 colours</a>
        </p>
      </div>
    </div>
  </section>

  <section class="section section--panel">
    <div class="container editorial-split">
      <div>
        <span class="section__eyebrow">Resources</span>
        <h2>Manufacturer guides</h2>
      </div>
      <div>
        <ul class="topic-list">
          {GUIDES.map(({ label, href }) => (
            <li><a href={href}><strong>{label}</strong></a></li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container editorial-split">
      <div>
        <span class="section__eyebrow">Supply</span>
        <h2>International delivery</h2>
      </div>
      <div>
        <p class="section__lead section__lead--wide">
          Professional orders ship via DHL Express with clear production timelines. We support single-chair studios, salon groups, distributors, and private label brands with consistent batch quality.
        </p>
      </div>
    </div>
  </section>

  <CTASection heading="Speak with our production team" text="Share your methods, shade range, and supply model — we respond via WhatsApp during business hours." />
</BaseLayout>
