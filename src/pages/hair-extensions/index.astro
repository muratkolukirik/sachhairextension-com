---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import ConsultationCTA from '../../components/ConsultationCTA.astro';
import { CATEGORIES, GUIDES, WHOLESALE } from '../../data/site';

const title = 'Human Hair Extensions for Salons';
const description =
  'Human hair extension systems manufactured by Sach & Vogue Hair — tape-in, keratin tip, weft, clip-in, topper, wholesale supply, private label, and 141-colour expertise.';
const breadcrumbs = [{ label: 'Hair Extensions', href: '/hair-extensions/' }];
---

<BaseLayout {title} {description} path="/hair-extensions/" {breadcrumbs}>
  <section class="page-intro">
    <div class="container">
      <Breadcrumbs items={breadcrumbs} />
      <h1>Human hair extensions for professional salons</h1>
      <p class="section__lead">
        Manufacturer-direct extension systems from sorted bulk human hair — Tape-In, Keratin Tip, Weft, Clip-In, and Women Topper — with 141-colour pigment work and international salon supply.
      </p>
    </div>
  </section>

  <section class="section section--compact">
    <div class="container article-body--wide">
      <div class="prose">
        <p>Sach &amp; Vogue Hair manufactures extension systems for stylists who need predictable quality across reorders. We control production at our Fethiye / Ölüdeniz facility — bulk hair selection, sorting, pigment-based colouring, method-specific construction, and quality review — rather than repackaging third-party goods.</p>
        <p>Choosing the right method depends on client density, lifestyle, maintenance preferences, and consultation depth. Each category below explains manufacturing logic, salon applications, and ordering considerations.</p>
      </div>

      <div class="card-grid">
        {CATEGORIES.map(({ title: catTitle, href, description: catDesc }) => (
          <article class="card">
            <h2 class="card__title"><a href={href}>{catTitle}</a></h2>
            <p class="card__text">{catDesc}</p>
            <a href={href} class="text-link">View details</a>
          </article>
        ))}
      </div>

      <div class="prose prose--follow">
        <h2>Women Topper pieces</h2>
        <p>For clients who need targeted volume or coverage rather than a full extension install, we produce Women Topper units in complementary shades from our 141-colour range — with the same pigment discipline applied across all lines.</p>

        <h2>Wholesale &amp; private label</h2>
        <p>Salons, distributors, and boutique brands source manufacturer-direct through our wholesale and private label programmes:</p>
        <ul class="topic-list">
          {WHOLESALE.map(({ label, href }) => (
            <li><a href={href}><strong>{label}</strong></a></li>
          ))}
        </ul>

        <h2>Manufacturer guides</h2>
        <ul class="topic-list">
          {GUIDES.map(({ label, href }) => (
            <li><a href={href}><strong>{label}</strong></a></li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <ConsultationCTA heading="Discuss your salon range" text="Tell us which methods you install most often and we will recommend lengths, weights, shades, and supply structure." />
</BaseLayout>
