---
import { SITE, CATEGORIES, NAV } from '../data/site';
---

<footer class="footer">
  <div class="container footer__grid">
    <div class="footer__brand">
      <p class="footer__name">{SITE.name}</p>
      <p class="footer__text">Premium human hair extensions manufacturer based in {SITE.location}. We supply salons and professional clients with bulk hair systems, colour expertise, and reliable international delivery.</p>
    </div>
    <div>
      <p class="footer__heading">Explore</p>
      <ul class="footer__links">
        {NAV.map(({ label, href }) => (<li><a href={href}>{label}</a></li>))}
        <li><a href="/hair-extension-weight-guide/">Weight Guide</a></li>
      </ul>
    </div>
    <div>
      <p class="footer__heading">Categories</p>
      <ul class="footer__links">
        {CATEGORIES.map(({ title, href }) => (<li><a href={href}>{title}</a></li>))}
      </ul>
    </div>
    <div>
      <p class="footer__heading">Contact</p>
      <address class="footer__address">
        {SITE.address.street}<br />{SITE.address.city}, {SITE.address.postalCode}<br />{SITE.location}
      </address>
      <ul class="footer__links footer__links--contact">
        <li><a href={`tel:${SITE.phone.replace(/\s/g, '')}`}>{SITE.phone}</a></li>
        <li><a href={SITE.whatsapp} target="_blank" rel="noopener noreferrer">WhatsApp</a></li>
        <li><a href={SITE.instagram} target="_blank" rel="noopener noreferrer">Instagram</a></li>
        <li><a href={SITE.mainSite} target="_blank" rel="noopener noreferrer">sachhair.com</a></li>
      </ul>
    </div>
  </div>
  <div class="container footer__bottom">
    <p>&copy; {new Date().getFullYear()} {SITE.name}. All rights reserved.</p>
  </div>
</footer>

<style>
  .footer { background: var(--color-charcoal); color: rgba(250, 248, 245, 0.75); padding-top: 3.5rem; }
  .footer__grid { display: grid; gap: 2.5rem; grid-template-columns: repeat(auto-fit, minmax(min(100%, 14rem), 1fr)); padding-bottom: 2.5rem; border-bottom: 1px solid rgba(255, 255, 255, 0.08); }
  .footer__name { font-family: var(--font-display); font-size: 1.375rem; color: var(--color-ivory); margin: 0 0 0.75rem; }
  .footer__text { font-size: 0.875rem; line-height: 1.65; margin: 0; }
  .footer__heading { font-size: 0.75rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-gold-soft); margin: 0 0 1rem; }
  .footer__links { list-style: none; padding: 0; margin: 0; }
  .footer__links li + li { margin-top: 0.5rem; }
  .footer__links a { color: rgba(250, 248, 245, 0.75); text-decoration: none; font-size: 0.875rem; }
  .footer__links a:hover { color: var(--color-gold-soft); }
  .footer__address { font-style: normal; font-size: 0.875rem; line-height: 1.65; margin-bottom: 1rem; }
  .footer__bottom { padding: 1.5rem 0; }
  .footer__bottom p { margin: 0; font-size: 0.8125rem; color: rgba(250, 248, 245, 0.5); }
</style>
