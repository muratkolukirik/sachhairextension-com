---
import { SITE, CATEGORIES, NAV, WHOLESALE, GUIDES } from '../data/site';
---

<footer class="footer">
  <div class="container">
    <hr class="line footer__line" />
    <div class="footer__grid">
      <div class="footer__brand">
        <p class="footer__name">{SITE.name}</p>
        <p class="footer__text">
          Premium human hair extensions manufacturer in {SITE.location}. Bulk hair production, 141-colour pigment work, private label capability, and international salon supply.
        </p>
      </div>

      <div>
        <p class="footer__heading">Explore</p>
        <ul class="footer__links">
          {NAV.map(({ label, href }) => (<li><a href={href}>{label}</a></li>))}
        </ul>
      </div>

      <div>
        <p class="footer__heading">Categories</p>
        <ul class="footer__links">
          {CATEGORIES.map(({ title, href }) => (<li><a href={href}>{title}</a></li>))}
        </ul>
      </div>

      <div>
        <p class="footer__heading">Wholesale</p>
        <ul class="footer__links">
          {WHOLESALE.map(({ label, href }) => (<li><a href={href}>{label}</a></li>))}
        </ul>
      </div>

      <div>
        <p class="footer__heading">Manufacturer Guides</p>
        <ul class="footer__links">
          {GUIDES.map(({ label, href }) => (<li><a href={href}>{label}</a></li>))}
        </ul>
      </div>

      <div>
        <p class="footer__heading">Contact</p>
        <address class="footer__address">
          {SITE.address.street}<br />
          {SITE.address.city}, {SITE.address.postalCode}<br />
          {SITE.location}
        </address>
        <ul class="footer__links">
          <li><a href={`tel:${SITE.phone.replace(/\s/g, '')}`}>{SITE.phone}</a></li>
          <li><a href={SITE.whatsapp} target="_blank" rel="noopener noreferrer">WhatsApp</a></li>
          <li><a href={SITE.instagram} target="_blank" rel="noopener noreferrer">Instagram</a></li>
          <li><a href={SITE.mainSite} target="_blank" rel="noopener noreferrer">sachhair.com</a></li>
        </ul>
      </div>
    </div>

    <div class="footer__bottom">
      <p>&copy; {new Date().getFullYear()} {SITE.name}</p>
      <p class="footer__locale">Fethiye / Ölüdeniz · Türkiye</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    padding: clamp(3rem, 8vw, 5rem) 0 clamp(2rem, 5vw, 3rem);
    background: var(--color-ivory);
  }

  .footer__line {
    margin-bottom: clamp(2.5rem, 6vw, 4rem);
  }

  .footer__grid {
    display: grid;
    gap: clamp(2rem, 5vw, 3rem);
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 12rem), 1fr));
    padding-bottom: clamp(2.5rem, 6vw, 4rem);
  }

  .footer__name {
    font-family: var(--font-display);
    font-size: 1.375rem;
    color: var(--color-charcoal);
    margin: 0 0 1rem;
  }

  .footer__text {
    font-size: 0.9375rem;
    font-weight: 300;
    line-height: 1.75;
    color: var(--color-charcoal-muted);
    margin: 0;
    max-width: 22rem;
  }

  .footer__heading {
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-champagne);
    margin: 0 0 1.25rem;
  }

  .footer__links {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer__links li + li {
    margin-top: 0.625rem;
  }

  .footer__links a {
    font-size: 0.875rem;
    font-weight: 400;
    color: var(--color-charcoal-soft);
    text-decoration: none;
  }

  .footer__links a:hover {
    color: var(--color-charcoal);
  }

  .footer__address {
    font-style: normal;
    font-size: 0.875rem;
    font-weight: 300;
    line-height: 1.75;
    color: var(--color-charcoal-soft);
    margin: 0 0 1.25rem;
  }

  .footer__bottom {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.75rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-line);
  }

  .footer__bottom p {
    margin: 0;
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-charcoal-muted);
  }
</style>
