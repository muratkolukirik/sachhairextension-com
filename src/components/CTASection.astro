---
import { SITE } from '../data/site';

interface Props {
  heading?: string;
  text?: string;
}

const {
  heading = 'Speak with our team',
  text = 'Share your salon requirements, preferred extension method, or colour brief. We respond via WhatsApp during business hours.',
} = Astro.props;
---

<section class="section section--compact cta-band">
  <div class="container cta-band__inner">
    <span class="section__eyebrow">Enquiries</span>
    <h2>{heading}</h2>
    <p>{text}</p>
    <a href={SITE.whatsapp} class="btn btn--soft" target="_blank" rel="noopener noreferrer">Contact via WhatsApp</a>
  </div>
</section>
