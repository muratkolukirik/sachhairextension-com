---
import { SITE } from '../data/site';

interface Props {
  heading?: string;
  text?: string;
  button?: string;
}

const {
  heading = 'Professional consultation',
  text = 'Speak with our production team about methods, colour, weight, and ordering structure.',
  button = 'Contact via WhatsApp',
} = Astro.props;
---

<section class="consultation-cta">
  <div class="container consultation-cta__inner">
    <span class="section__eyebrow">Consultation</span>
    <h2>{heading}</h2>
    <p>{text}</p>
    <a href={SITE.whatsapp} class="btn btn--soft" target="_blank" rel="noopener noreferrer">{button}</a>
  </div>
</section>
