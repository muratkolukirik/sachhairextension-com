---
import { SITE, NAV } from '../data/site';
const currentPath = Astro.url.pathname;
---

<header class="header">
  <div class="container header__inner">
    <a href="/" class="header__brand" aria-label={`${SITE.name} home`}>
      <span class="header__name">{SITE.name}</span>
      <span class="header__tagline">Hair Extensions Manufacturer</span>
    </a>
    <button class="header__toggle" type="button" aria-expanded="false" aria-controls="site-nav" aria-label="Toggle navigation">
      <span class="header__toggle-bar"></span>
      <span class="header__toggle-bar"></span>
    </button>
    <nav id="site-nav" class="header__nav" aria-label="Main navigation">
      <ul class="header__list">
        {NAV.map(({ label, href }) => (
          <li>
            <a href={href} class:list={['header__link', { 'header__link--active': currentPath === href || (href !== '/' && currentPath.startsWith(href)) }]} aria-current={currentPath === href ? 'page' : undefined}>{label}</a>
          </li>
        ))}
      </ul>
      <a href={SITE.whatsapp} class="btn btn--whatsapp header__cta" target="_blank" rel="noopener noreferrer">WhatsApp</a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.querySelector('.header__toggle');
  const nav = document.querySelector('.header__nav');
  toggle?.addEventListener('click', () => {
    const expanded = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!expanded));
    nav?.classList.toggle('header__nav--open');
  });
</script>

<style>
  .header { position: sticky; top: 0; z-index: 100; background: rgba(250, 248, 245, 0.92); backdrop-filter: blur(12px); border-bottom: 1px solid var(--color-beige); }
  .header__inner { display: flex; align-items: center; justify-content: space-between; min-height: var(--header-height); gap: 1rem; }
  .header__brand { text-decoration: none; color: inherit; }
  .header__name { display: block; font-family: var(--font-display); font-size: 1.375rem; font-weight: 600; color: var(--color-charcoal); line-height: 1.2; }
  .header__tagline { display: block; font-size: 0.6875rem; font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase; color: var(--color-gold); }
  .header__toggle { display: none; flex-direction: column; justify-content: center; gap: 0.375rem; width: 2.5rem; height: 2.5rem; padding: 0; background: none; border: 1px solid var(--color-beige); border-radius: var(--radius); cursor: pointer; }
  .header__toggle-bar { display: block; width: 1.125rem; height: 1px; margin-inline: auto; background: var(--color-charcoal); }
  .header__nav { display: flex; align-items: center; gap: 2rem; }
  .header__list { display: flex; gap: 1.75rem; list-style: none; margin: 0; padding: 0; }
  .header__link { font-size: 0.875rem; font-weight: 500; color: var(--color-charcoal-soft); text-decoration: none; }
  .header__link:hover, .header__link--active { color: var(--color-gold); }
  .header__cta { padding: 0.625rem 1.25rem; font-size: 0.8125rem; }
  @media (max-width: 768px) {
    .header__toggle { display: flex; }
    .header__nav { position: absolute; top: var(--header-height); left: 0; right: 0; flex-direction: column; align-items: stretch; gap: 1.5rem; padding: 1.5rem; background: var(--color-ivory); border-bottom: 1px solid var(--color-beige); display: none; }
    .header__nav--open { display: flex; }
    .header__list { flex-direction: column; gap: 1rem; }
    .header__cta { text-align: center; }
  }
</style>
